# pzt-agent 运行所需的环境变量样例。
# 拷一份改名(如 ~/.pzt-agent.env),填好后:
#   set -a; source ~/.pzt-agent.env; set +a
#   pzt-agent
# brew 装的用户可从 "$(brew --prefix)/share/pzt-agent/pzt-agent.env.example" 拷。

# --- Telegram(必填)---
# @BotFather 建 bot 拿到的 token
TELEGRAM_BOT_TOKEN=
# 只接受这个 chat 的消息(单用户自托管);拿自己的 chat_id 见 agent/README.md
TELEGRAM_CHAT_ID=

# --- AI 语言推理 provider(可选,默认 local)---
# local = 本地 Ollama(需 ollama 起着 + ollama pull gemma4:e2b)
# gemini / claude = 云端(需相应 API key 环境变量)
PZT_AGENT_META_PROVIDER=local

# --- pzt 二进制定位(可选)---
# brew 装了 pzt 就在 PATH 上,无需设。仅当想指定别的 pzt 时才取消注释。
# PZT_BIN=/opt/homebrew/bin/pzt
